# ── LLM providers ────────────────────────────────────
OPENAI_API_KEY=sk-...
MISTRAL_API_KEY=...

# ── Models ───────────────────────────────────────────
OPENAI_MODEL=gpt-4o
MISTRAL_MODEL=mistral-large-latest
EMBED_MODEL=text-embedding-3-small

# ── RAG ──────────────────────────────────────────────
CHROMA_PATH=./data/chroma
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_K=6

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
